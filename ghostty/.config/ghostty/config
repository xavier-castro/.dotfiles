font-family = CaskaydiaCove Nerd Font
background-opacity = 0.95
background-blur-radius = 25
window-colorspace = display-p3


cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = false
cursor-opacity = .8
shell-integration-features = no-cursor


macos-option-as-alt = left
keybind = alt+left=unbind
keybind = alt+right=unbind

font-feature = -calt
font-feature = -liga
font-feature = -dlig
adjust-underline-position = 2
adjust-cell-height = -1

# Windows, colors and styles
# theme = rose-pine-muted
# macos-titlebar-style = hidden
window-padding-y = 2,0
window-padding-x = 2
window-padding-balance = true

# macOS stuff
macos-option-as-alt = left
macos-window-shadow = false

# Keys
# Ascii device control codes: https://www3.rocketsoftware.com/bluezone/help/v42/en/bzadmin/APPENDIX_C/ASCII_Character_Set.htm
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = super+enter=unbind

# Tmux-sessionizer: Ctrl-f+S (.zshrc binds this to `s\n`, since `s` is an alias
# for tmux-sessionizer)
keybind = cmd+s=text:\x06\x53
keybind = cmd+b=text:\x06\x42
